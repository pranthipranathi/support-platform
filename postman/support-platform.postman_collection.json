    },
    {
      "name": "AI Assistant",
      "item": [
        {
          "name": "Analyze Ticket",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/ai/tickets/:ticketId/analyze", "host": ["{{baseUrl}}"], "path": ["ai", "tickets", ":ticketId", "analyze"], "variable": [{ "key": "ticketId", "value": "" }] }
          }
        },
        {
          "name": "Summarize Ticket",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/ai/tickets/:ticketId/summarize", "host": ["{{baseUrl}}"], "path": ["ai", "tickets", ":ticketId", "summarize"], "variable": [{ "key": "ticketId", "value": "" }] }
          }
        },
        {
          "name": "Generate Reply",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/ai/tickets/:ticketId/reply?customerMessage=I need help urgently", "host": ["{{baseUrl}}"], "path": ["ai", "tickets", ":ticketId", "reply"], "query": [{ "key": "customerMessage", "value": "I need help urgently" }], "variable": [{ "key": "ticketId", "value": "" }] }
